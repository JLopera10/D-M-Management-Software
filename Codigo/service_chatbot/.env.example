# =============================================================================
# Chatbot Gemini (US-04) — copie este archivo a .env si aún no tiene uno:
#   copy .env.example .env   (Windows)   |   cp .env.example .env   (Linux/macOS)
# Luego pegue solo su GEMINI_API_KEY y reinicie Django (puerto 8005) y Vite si aplica.
# =============================================================================

# Obligatorio: clave desde https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opcional. No use gemini-1.5-flash (suele dar 404). Por defecto: gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
